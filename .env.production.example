PORT=4000

# Single analyst password used by the Fr&dCl@ssic login screen.
APP_ACCESS_PASSWORD=

# Optional HMAC secret for signing session cookies. Falls back to APP_ACCESS_PASSWORD when omitted.
APP_SESSION_SECRET=

CORTEX_ENABLED=false
CORTEX_BASE_URL=
CORTEX_API_KEY=
CORTEX_TIMEOUT_MS=15000
CORTEX_ANALYZERS_EML=
CORTEX_ANALYZERS_URL=
CORTEX_ANALYZERS_DOMAIN=
CORTEX_ANALYZERS_FILE_HASH=

# Optional self-hosted Cortex runtime. This runtime lives under /opt/phishing/shared on the server,
# so CI deploys can restart or verify it without storing it inside rotating app releases.
CORTEX_RUNTIME_ENABLED=false
CORTEX_RUNTIME_PORT=9001
CORTEX_RUNTIME_ELASTICSEARCH_PORT=9201
CORTEX_RUNTIME_IMAGE=thehiveproject/cortex:4.0.1
CORTEX_RUNTIME_ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.19.0
CORTEX_RUNTIME_ES_JAVA_OPTS=-Xms1g -Xmx1g
CORTEX_RUNTIME_ANALYZER_URLS=https://catalogs.download.strangebee.com/latest/json/analyzers.json
CORTEX_RUNTIME_RESPONDER_URLS=https://catalogs.download.strangebee.com/latest/json/responders.json

VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
URLHAUS_AUTH_KEY=
FILE_ANALYSIS_YARA_COMMAND=yara -r /opt/yara/rules/index.yar :path
FILE_ANALYSIS_CLAMAV_COMMAND=clamscan --no-summary :path

# Self-hosted browser sandbox on the Linux server.
# The noVNC WebSocket "path" parameter is auto-injected by the backend when the
# URL ends with /vnc.html and no explicit path= is present.
BROWSER_SANDBOX_PROVIDER=local-novnc
BROWSER_SANDBOX_ACCESS_MODE=embedded
BROWSER_SANDBOX_ACCESS_BASE_URL=
BROWSER_SANDBOX_ACCESS_URL_TEMPLATE=https://fred.syntrix.ae/novnc/:novncPort/vnc.html?autoconnect=1&resize=remote
BROWSER_SANDBOX_ACCESS_PATH_TEMPLATE=:jobId
BROWSER_SANDBOX_START_COMMAND=bash scripts/sandbox/start-local-browser-sandbox.sh :jobId :url :displayNumber :vncPort :novncPort :cdpPort :sessionDir
BROWSER_SANDBOX_STOP_COMMAND=bash scripts/sandbox/stop-local-browser-sandbox.sh :jobId :sessionDir